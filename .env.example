# AmeyemGeo environment. Copy to .env and fill in. NEVER commit the real .env.

# Postgres (Neon) — required by the app in general.
DATABASE_URL=postgres://user:pass@host/db
NODE_ENV=development

# --- Sales-lead delivery (server/leads.ts) --------------------------------
# Every lead is ALWAYS persisted to data/leads.jsonl. The settings below add
# real-time notification so nobody has to watch that file. Configure EITHER a
# webhook (simplest, zero extra deps) OR SMTP. If neither is set, leads are
# still saved to disk and a warning is logged.

# Webhook: a Slack/Discord incoming-webhook URL, a Formspree endpoint, or any
# URL that accepts a JSON POST. Slack/Discord work out of the box (we send {text}).
LEAD_WEBHOOK_URL=

# SMTP (used only if LEAD_WEBHOOK_URL is unset/failing). Requires `pnpm add nodemailer`.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@ameyem.com
# Where lead notifications are emailed (defaults to sales@ameyem.com).
LEAD_TO=sales@ameyem.com
